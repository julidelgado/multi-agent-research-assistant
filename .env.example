# Core mode: heuristic (default, no local model needed) or ollama (local model).
MARA_LLM_PROVIDER=heuristic

# Used only when MARA_LLM_PROVIDER=ollama
MARA_OLLAMA_BASE_URL=http://localhost:11434
MARA_OLLAMA_MODEL=llama3.1:8b

# Pipeline settings
MARA_MAX_QUERIES=5
MARA_MAX_RESULTS_PER_QUERY=8
MARA_MAX_DOCUMENTS=10
MARA_MIN_DOCUMENT_CHARS=800

